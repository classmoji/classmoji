{
  "name": "@classmoji/mcp",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "mcp:dev": "node --watch --experimental-strip-types src/index.ts",
    "mcp:start": "node --experimental-strip-types src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "dependencies": {
    "@classmoji/auth": "*",
    "@classmoji/database": "*",
    "@classmoji/services": "*",
    "@classmoji/tasks": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trigger.dev/sdk": "4.4.0",
    "fastify": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
