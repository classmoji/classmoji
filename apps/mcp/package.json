{
  "name": "@classmoji/mcp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "mcp:dev": "node --watch --experimental-strip-types --no-warnings src/index.ts",
    "mcp:start": "node --experimental-strip-types --no-warnings src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "dependencies": {
    "@classmoji/auth": "*",
    "@classmoji/content": "*",
    "@classmoji/database": "*",
    "@classmoji/services": "*",
    "@classmoji/utils": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "vitest": "^3.2.4"
  }
}
