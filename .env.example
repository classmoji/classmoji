# =============================================================================
# Core
# =============================================================================

WEBAPP_URL="http://localhost:3000"
SLIDES_URL="http://localhost:6500"
PAGES_URL="http://localhost:7100"

DATABASE_URL="postgresql://classmoji:classmoji@localhost:5433/classmoji"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# =============================================================================
# GitHub Integration
# Set up via the wizard at localhost:3000/setup (requires SETUP_GITHUB_APP=true)
# =============================================================================

SETUP_GITHUB_APP="true"

GITHUB_APP_ID=""
GITHUB_APP_NAME=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_PRIVATE_KEY_BASE64=""

# Generate with: openssl rand -base64 32
GITHUB_WEBHOOK_SECRET="change-me-generate-with-openssl-rand-base64-32"

# Optional. Lifts the marketing site's build-time GitHub stars fetch from the
# 60/hour unauthenticated limit to 5,000/hour. CI (GitHub Actions) provides this
# automatically; only set it locally if repeated `site:build` runs hit a 403.
GITHUB_TOKEN=""

# =============================================================================
# Background Jobs / Trigger.dev
# Get your dev key at trigger.dev → API Keys → Development
# =============================================================================

TRIGGER_SECRET_KEY=""

# Optional: override the Trigger.dev project id. Leave blank to use the
# shared staging/prod project. Set this if you are developing against your
# own Trigger.dev project.
TRIGGER_PROJECT_ID=""

# =============================================================================
# Email (optional)
# =============================================================================

EMAIL=""
EMAIL_PASSWORD=""
# SMTP transport (optional overrides; defaults to Namecheap Private Email used in prod).
# For local dev with Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=465, EMAIL_SECURE=true
# (EMAIL_PASSWORD must be a Google App Password, not your normal Gmail password.)
EMAIL_HOST=""
EMAIL_PORT=""
EMAIL_SECURE=""

# =============================================================================
# Media / Cloudinary (optional)
# =============================================================================

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# =============================================================================
# Other
# =============================================================================

# Generate with: openssl rand -base64 32
CALENDAR_SECRET="change-me-generate-with-openssl-rand-base64-32"

# =============================================================================
# AI Features (optional)
# =============================================================================

AI_AGENT_URL="http://localhost:6000"

# Generate with: openssl rand -hex 32
AI_AGENT_SHARED_SECRET="change-me-generate-with-openssl-rand-hex-32"

LLM_PROVIDER="anthropic"
LLM_MODEL="claude-sonnet-4-5-20250929"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

EXPLORATION_MODE="trigger"
EXPLORATION_MODEL="claude-haiku-4-5-20251001"
