# =============================================================================
# Core
# =============================================================================

WEBAPP_URL="http://localhost:3000"
SLIDES_URL="http://localhost:6500"
PAGES_URL="http://localhost:7100"

# MCP resource server (apps/mcp). MCP_PUBLIC_URL is the externally reachable
# origin advertised in the OAuth protected-resource metadata (RFC 9728) and in
# WWW-Authenticate challenges — must match how MCP clients reach the server.
# In production both are required (MCP_PUBLIC_URL is asserted at startup) and
# set as Fly secrets / fly.toml env, not from this file. The MCP server also
# needs DATABASE_URL, BETTER_AUTH_SECRET, WEBAPP_URL, and TRIGGER_SECRET_KEY
# at runtime (regrade/publish tools trigger Trigger.dev tasks).
MCP_PUBLIC_URL="http://localhost:8100"
MCP_PORT="8100"

# Reserved for future MCP audience validation (RFC 8707 resource indicators).
# Currently UNUSED by code — do not set in any deploy config.
# MCP_AUDIENCE=""

# Dev/test ONLY. Double-gates the webapp's /test-login route and the MCP
# server's POST /dev/mint-token endpoint (both also require
# NODE_ENV=development). NEVER set this in staging/production — CI
# (mcp-devmint-guard) fails if it appears in apps/mcp deploy config.
ENABLE_TEST_LOGIN="false"

DATABASE_URL="postgresql://classmoji:classmoji@localhost:5433/classmoji"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# =============================================================================
# GitHub Integration
# Set up via the wizard at localhost:3000/setup (requires SETUP_GITHUB_APP=true)
# =============================================================================

SETUP_GITHUB_APP="true"

GITHUB_APP_ID=""
GITHUB_APP_NAME=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_PRIVATE_KEY_BASE64=""

# Generate with: openssl rand -base64 32
GITHUB_WEBHOOK_SECRET="change-me-generate-with-openssl-rand-base64-32"

# Signs the per-classroom HMAC token embedded in the autograding workflow
# (.github/workflows/classroom.yml). The workflow reports results by triggering
# the `ingest_autograde_result` Trigger.dev task, which verifies this token.
# Generate with: openssl rand -hex 32. If unset, autograding still runs but
# results are not reported back to Classmoji.
AUTOGRADE_CALLBACK_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Optional. Lifts the marketing site's build-time GitHub stars fetch from the
# 60/hour unauthenticated limit to 5,000/hour. CI (GitHub Actions) provides this
# automatically; only set it locally if repeated `site:build` runs hit a 403.
GITHUB_TOKEN=""

# =============================================================================
# Background Jobs / Trigger.dev
# Get your dev key at trigger.dev → API Keys → Development
# Needed by the webapp, hook-station, AND the MCP server (apps/mcp) at
# runtime — MCP regrade/publish tools trigger Trigger.dev tasks.
# =============================================================================

TRIGGER_SECRET_KEY=""

# Optional: override the Trigger.dev project id. Leave blank to use the
# shared staging/prod project. Set this if you are developing against your
# own Trigger.dev project.
TRIGGER_PROJECT_ID=""

# =============================================================================
# Email (optional)
# =============================================================================

EMAIL=""
EMAIL_PASSWORD=""
# SMTP transport (optional overrides; defaults to Namecheap Private Email used in prod).
# For local dev with Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=465, EMAIL_SECURE=true
# (EMAIL_PASSWORD must be a Google App Password, not your normal Gmail password.)
EMAIL_HOST=""
EMAIL_PORT=""
EMAIL_SECURE=""

# =============================================================================
# Media / Cloudinary (optional)
# =============================================================================

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# =============================================================================
# Other
# =============================================================================

# Generate with: openssl rand -base64 32
CALENDAR_SECRET="change-me-generate-with-openssl-rand-base64-32"

# =============================================================================
# AI Features (optional)
# =============================================================================

AI_AGENT_URL="http://localhost:6000"

# Generate with: openssl rand -hex 32
AI_AGENT_SHARED_SECRET="change-me-generate-with-openssl-rand-hex-32"

LLM_PROVIDER="anthropic"
LLM_MODEL="claude-sonnet-4-5-20250929"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

EXPLORATION_MODE="trigger"
EXPLORATION_MODEL="claude-haiku-4-5-20251001"
